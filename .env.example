# ─────────────────────────────────────────────────
#  Priority Bags — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Supabase PostgreSQL — from: Dashboard → Settings → Database → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRE=24h

# App
NODE_ENV=production
PORT=3000

# CORS — set to your Vercel URL after first deploy
ALLOWED_ORIGIN=https://your-app.vercel.app

# Frontend API base URL (leave empty when frontend & backend are on the same domain)
VITE_API_URL=

# Razorpay — from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay public key exposed to frontend via Vite (key_id only, never the secret)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
